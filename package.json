{
  "name": "vite-express-ts",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n vite,api \"npm run vite:dev:wait\" \"npm run api:dev\"",
    "build": "npm run vite:build && npm run api:build",
    "start": "node ./.local/express/dist/api.js",
    "vite:build": "vite build --emptyOutDir",
    "vite:dev": "vite",
    "vite:dev:wait": "wait-on http://localhost:9001/api/v1/health && vite",
    "api:build": "node esbuild.mjs",
    "api:build:watch": "npm run api:build -- --watch",
    "api:dev": "rimraf ./.local/express/dist && cross-env NODE_ENV=development npm run api:build:watch",
    "api:prod": "cross-env NODE_ENV=production node ./.local/express/dist/api.js",
    "tsc": "tsc --pretty",
    "lint": "concurrently -n js,css \"npm run lint:js\" \"npm run lint:css\"",
    "lint:js": "eslint . --color",
    "lint:js:fix": "eslint . --fix --color",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint:css:fix": "stylelint \"src/**/*.css\" --fix",
    "test": "vitest run --config vitest.config.mts",
    "test:coverage": "vitest run --coverage --config vitest.config.mts",
    "test:all": "npm run lint && npm run tsc && npm run build && npm run test",
    "docker:preview": "docker compose -f docker-compose.yml up -d",
    "docker:preview:rebuild": "docker compose -f docker-compose.yml build",
    "docker:preview:rebuild:nocache": "docker compose -f docker-compose.yml build --no-cache"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lodash": "^4.18.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/css-modules": "^1.0.5",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-css-modules": "^2.12.0",
    "eslint-plugin-package-json": "^0.91.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "stylelint": "^17.12.0",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  }
}
